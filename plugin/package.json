{
  "name": "@hawtio/ai-plugin",
  "version": "0.1.6",
  "description": "Hawtio AI plugin",
  "main": "./dist/index.js",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "webpack serve --mode development",
    "build:webpack": "webpack --mode production",
    "build:tsup": "tsup --clean",
    "test": "jest --passWithNoTests",
    "format:check": "yarn prettier --check .",
    "format:fix": "yarn prettier --write .",
    "replace-version": "replace __PACKAGE_VERSION_PLACEHOLDER__ -r --include=\"*.js\"",
    "release": "commit-and-tag-version",
    "prepack": "yarn build:tsup && yarn replace-version $npm_package_version ./dist"
  },
  "dependencies": {
    "@hawtio/react": "^2.2.0",
    "@langchain/anthropic": "^1.3.27",
    "@langchain/core": "^1.1.41",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "@patternfly/react-charts": "^8.4.0",
    "@patternfly/react-code-editor": "^6.4.0",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@patternfly/react-tokens": "^6.4.0",
    "langchain": "^1.2.39",
    "monaco-editor": "~0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@hawtio/backend-middleware": "^1.0.8",
    "@swc/core": "^1.15.18",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "commit-and-tag-version": "^12.7.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "cz-conventional-changelog": "^3.3.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "prettier": "3.8.3",
    "replace": "^1.2.2",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.3"
  },
  "resolutions": {
    "@module-federation/utilities": "3.1.83"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog",
      "maxLineWidth": 80
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.14.1"
}
